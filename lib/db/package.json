{
  "name": "@workspace/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./permissionCatalog": "./src/permissionCatalog.ts"
  },
  "scripts": {
    "push": "drizzle-kit push --config ./drizzle.config.ts",
    "push-force": "drizzle-kit push --force --config ./drizzle.config.ts",
    "generate": "drizzle-kit generate --config ./drizzle.config.ts",
    "rebuild-snapshots": "node ./scripts/rebuild-snapshots-from-migrations.mjs",
    "migrate": "tsx src/migrate.ts",
    "apply-fh-ddl": "tsx src/applyFactoryHubDdl.ts",
    "apply-auth-ddl": "tsx src/applyAuthAuditDdl.ts",
    "seed-permissions": "tsx src/seedPermissions.ts",
    "export-permission-docs": "tsx src/exportPermissionDocs.ts",
    "seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "drizzle-orm": "catalog:",
    "drizzle-zod": "^0.8.3",
    "xlsx": "^0.18.5",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "drizzle-kit": "^0.31.9"
  }
}
