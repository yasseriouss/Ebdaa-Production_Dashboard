# مثال متغيرات البيئة — انسخ إلى `.env` وعدّل

# --- قاعدة البيانات (واحد يكفي عادةً) ---
# عنوان LibSQL كامل (ملف محلي أو Turso لاحقًا):
# LIBSQL_URL=file:C:/path/to/Factory-Data-Hub/local.db
# أو مسار ملف يُحوَّل تلقائيًا إلى file: URL:
# SQLITE_FILE=./local.db

# --- خادم الـ API (يطابق بروكسي Vite في apps/web و factory-app؛ الافتراضي في الكود 8787) ---
PORT=8787

# --- واجهة factory-app (Vite) ---
# نفس PORT إن شغّلت الواجهة منفصلة، أو منفذ آخر مع تعديل البروكسي في vite.config
BASE_PATH=/

# إظهار صفحة المخططات الداخلية /__internal/project-atlas في غير وضع التطوير (اختياري)
# VITE_SHOW_PROJECT_ATLAS=1

# --- ETL (اختياري) ---
# SOURCE_DATABASE_URL=postgresql://user:pass@host:5432/dbname
# ETL_APPLY=1                    # ضعه لتنفيذ الإدخال في SQLite؛ بدونه يعمل السكربت جافًا
# ETL_WIPE_SQLITE=1             # مع ETL_APPLY: حذف بيانات الجداول المدعومة قبل النسخ (خطير)
