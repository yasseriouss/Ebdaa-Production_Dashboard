flowchart TB
  subgraph demand["المحفزات والطلب / Demand triggers"]
    d1["طلب عميل جديد أو تعديل كمية"]
    d2["مشروع مشترك معدن وأخشاب"]
    d3["أولوية عاجلة أو تاريخ تسليم مبكر"]
    d4["إعادة عمل جودة أو انحراف عن المسار"]
    d5["تأخر مورد أو توقف معدة"]
    d1 --> d2
    d3 --> d4
    d4 --> d5
  end

  subgraph actors["أصحاب المصلحة / Actors"]
    a1["الإدارة التنفيذية"]
    a2["التخطيط والجدولة"]
    a3["مشرف ومشغل مصنع المعادن"]
    a4["مشرف ومشغل مصنع الأخشاب"]
    a5["الجودة والمستودع"]
    a6["الأنظمة والتكامل"]
  end

  subgraph surfaces["قنوات التفاعل / Interaction surfaces"]
    s1["Factory OS ويب لوحة القيادة والوحدات"]
    s2["تطبيق أرضية المصنع RTL أوامر الخشب Kanban جدول"]
    s3["REST API معدن خشب لوحة معلومات استيراد تصدير"]
    s4["استيراد Excel تصدير تقارير"]
  end

  subgraph coreProc["المسار السعيد / Happy path core"]
    c1["تسجيل أوامر العمل MO أوامر الخشب"]
    c2["تعريف المراحل والكميات المستهدفة"]
    c3["تحديث التقدم وسجل مراحل المعدن"]
    c4["ربط المشاريع المشتركة والسعة"]
    c5["لوحات ومؤشرات وزمن تسليم"]
    c1 --> c2 --> c3 --> c4 --> c5
  end

  subgraph exceptions["جميع الاحتمالات الاستثنائية / Exception space"]
    e1["بيانات ناقصة أو غير متسقة"]
    e2["رفض صلاحية أو جلسة منتهية"]
    e3["تعارض تحديث أو نسخة قديمة"]
    e4["أمر غير موجود أو معرف خاطئ"]
    e5["فشل استيراد صيغة أو أعمدة"]
    e6["API غير متاح أو مهلة زمنية"]
    e7["وضع محلي فقط دون مزامنة"]
    e8["نفاد أو تأخر مادة"]
    e9["قرار إيقاف أو إلغاء أمر"]
  end

  subgraph outcomes["النتائج / Outcomes"]
    o1["رؤية موحدة للوضع عبر المصانع"]
    o2["تقدير أوضح للاختناقات والتسليم"]
    o3["أثر قابل للتدقيق على المراحل"]
    o4["تقارير للإدارة والعملاء"]
  end

  demand --> actors
  actors --> surfaces
  surfaces --> coreProc
  coreProc --> outcomes

  surfaces -.->|"احتمال"| e1
  surfaces -.->|"احتمال"| e2
  coreProc -.->|"احتمال"| e3
  coreProc -.->|"احتمال"| e4
  s4 -.->|"احتمال"| e5
  s3 -.->|"احتمال"| e6
  s2 -.->|"احتمال"| e7
  demand -.->|"احتمال"| e8
  actors -.->|"احتمال"| e9

  e1 --> recover["تصحيح بيانات وإعادة محاولة"]
  e2 --> recover2["إعادة تسجيل دخول أو طلب صلاحية"]
  e3 --> recover3["دمج يدوي أو إعادة تحميل"]
  e5 --> recover4["قالب صالح وإعادة رفع"]
  e6 --> recover5["إعادة المحاولة أو وضع غير متصل"]
  recover --> coreProc
  recover2 --> surfaces
  recover3 --> coreProc
  recover4 --> s4
