#PORT=8788
# LIBSQL_URL=file:./local.db

# في وضع التطوير (NODE_ENV=development) يكون الوصول للضيف غير المُصادَق «غير مقيّد» افتراضيًا — لا حاجة لتوكن JWT.
# للإنتاج الصارم: AUTH_ANONYMOUS_UNRESTRICTED=false
# إن شغّلت بناء إنتاجي محليًا بدون توكن: FDH_OFFLINE_UNRESTRICTED=1

# --- Optional auth (JWT) ---
# Minimum 16 characters. Required for POST /api/auth/login to return tokens.
# JWT_SECRET=

# Bootstrap admin password (8+ chars). Applies on server start to BOOTSTRAP_ADMIN_EMAIL (default demo@factory.local).
# BOOTSTRAP_ADMIN_PASSWORD=
# BOOTSTRAP_ADMIN_EMAIL=demo@factory.local

# When `false`, anonymous API clients get no permissions until they send a Bearer token (production-style).
# AUTH_ANONYMOUS_UNRESTRICTED=false

# --- Factory hub ---
# Mirror hub wood writes into wooden_work_orders after PUT /api/factory-hub/wood-work-orders/:id
# FH_SYNC_WOODEN=true

# Allow POST /api/factory-hub/seed outside NODE_ENV=development
# FH_ALLOW_SEED=true

# Disable HTTP mutation audit rows
# AUDIT_HTTP_DISABLED=true
PORT=8788
NODE_ENV=development

# SQLite at repo root (default when unset)
# SQLITE_FILE=../../local.db

JWT_SECRET=dev-factory-hub-jwt-secret
BOOTSTRAP_ADMIN_EMAIL=demo@factory.local
BOOTSTRAP_ADMIN_PASSWORD=FactoryDemo1!

LIBSQL_URL=libsql://factory-hub-yasserious.aws-eu-west-1.turso.io
