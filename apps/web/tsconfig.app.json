{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "ignoreDeprecations": "5.0",
    "paths": {
      "@factory/*": ["./src/factory/*"]
    }
  },
  "include": ["src"],
  "exclude": [
    "src/factory/components/ui/aspect-ratio.tsx",
    "src/factory/components/ui/avatar.tsx",
    "src/factory/components/ui/breadcrumb.tsx",
    "src/factory/components/ui/button-group.tsx",
    "src/factory/components/ui/calendar.tsx",
    "src/factory/components/ui/carousel.tsx",
    "src/factory/components/ui/chart.tsx",
    "src/factory/components/ui/collapsible.tsx",
    "src/factory/components/ui/command.tsx",
    "src/factory/components/ui/context-menu.tsx",
    "src/factory/components/ui/drawer.tsx",
    "src/factory/components/ui/dropdown-menu.tsx",
    "src/factory/components/ui/empty.tsx",
    "src/factory/components/ui/field.tsx",
    "src/factory/components/ui/form.tsx",
    "src/factory/components/ui/hover-card.tsx",
    "src/factory/components/ui/input-group.tsx",
    "src/factory/components/ui/input-otp.tsx",
    "src/factory/components/ui/item.tsx",
    "src/factory/components/ui/kbd.tsx",
    "src/factory/components/ui/menubar.tsx",
    "src/factory/components/ui/navigation-menu.tsx",
    "src/factory/components/ui/pagination.tsx",
    "src/factory/components/ui/popover.tsx",
    "src/factory/components/ui/radio-group.tsx",
    "src/factory/components/ui/resizable.tsx",
    "src/factory/components/ui/scroll-area.tsx",
    "src/factory/components/ui/separator.tsx",
    "src/factory/components/ui/sheet.tsx",
    "src/factory/components/ui/sidebar.tsx",
    "src/factory/components/ui/slider.tsx",
    "src/factory/components/ui/sonner.tsx",
    "src/factory/components/ui/spinner.tsx",
    "src/factory/components/ui/switch.tsx",
    "src/factory/components/ui/toggle-group.tsx",
    "src/factory/components/ui/toggle.tsx",
    "src/factory/components/ui/tooltip.tsx",
    "src/factory/pages/analytics.tsx",
    "src/factory/pages/planning.tsx",
    "src/factory/pages/not-found.tsx",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/test",
    "src/factory/components/ui/toaster.tsx"
  ],
  "references": [{ "path": "../../lib/api-client-react" }]
}
