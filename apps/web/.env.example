# انسخ إلى `.env.development.local` — لا يُرفع إلى Git عادةً

# أثناء العمل محليًا بدون مصادقة: لا ترسل توكن JWT مع الطلبات (يتجنب 401 من توكن قديم)
# VITE_OFFLINE_UNRESTRICTED=1

# --- Vercel (نشر apps/web) ---
# لوحة Vercel → Settings → General → Root Directory = apps/web
# Framework = Vite (يُكتشف من apps/web/vercel.json)
#
# متغير بيئة على Vercel (Production + Preview):
# FDH_API_UPSTREAM=https://your-api-host.example.com
#   → يوجّه /api/* عبر apps/web/api/[...path].ts (Edge) إلى خادم الـ API
#
# تطوير محلي: VITE_API_PROXY_TARGET (انظر vite.config.ts)
