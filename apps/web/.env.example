# انسخ إلى `.env.development.local` — لا يُرفع إلى Git عادةً

# أثناء العمل محليًا بدون مصادقة: لا ترسل توكن JWT مع الطلبات (يتجنب 401 من توكن قديم)
# VITE_OFFLINE_UNRESTRICTED=1

# --- Vercel (نشر apps/web كجذر المشروع) ---
# اضبط في لوحة Vercel: Root Directory = apps/web
# للـ API في الإنتاج: أضف rewrite إلى خادم API أو استخدم VITE_API_PROXY_TARGET عند البناء إن لزم
